#!/bin/env python3
"""Display open issues from a Gitea repository."""
# Requirements: python3 -m venv ~/.venv && ~/.venv/bin/pip3 install requests pyyaml colorama
# Usage: ~/.venv/bin/python3 ./SCRIPTS/gitea-issues
# Configuration file: ~/.config/gitea-issues.yml
# GITEA_URL
# GITEA_TOKEN
# MAX_LINES
# REQUESTS_TIMEOUT

import sys
import argparse
import os
from urllib.parse import quote

import colorama
import requests
import yaml

# Disable SSL warnings
import urllib3

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

colorama.init()

# load config from YAML file
config_path = os.path.expanduser('~/.config/gitea-issues.yml')
if not os.path.exists(config_path):
    print(f'{colorama.Fore.RED}ERROR: Config file {config_path} not found{colorama.Style.RESET_ALL}')
    sys.exit(1)

with open(config_path, 'r', encoding='utf-8') as config_file:
    CONFIG = yaml.safe_load(config_file)

GITEA_URL = CONFIG.get('GITEA_URL')
GITEA_TOKEN = CONFIG.get('GITEA_TOKEN')
MAX_LINES = int(CONFIG.get('MAX_LINES', 20))
REQUESTS_TIMEOUT = int(CONFIG.get('REQUESTS_TIMEOUT', 30))

if not GITEA_URL:
    print(f'{colorama.Fore.RED}ERROR: GITEA_URL not configured in {config_path}{colorama.Style.RESET_ALL}')
    sys.exit(1)

if not GITEA_TOKEN:
    print(f'{colorama.Fore.RED}ERROR: GITEA_TOKEN not configured in {config_path}{colorama.Style.RESET_ALL}')
    sys.exit(1)


def print_title(text):
    """Print section title to screen"""
    print(f'{colorama.Fore.GREEN}####### {text}{colorama.Style.RESET_ALL}')


def format_bullet_point(symbol, color, text):
    """Format a string as a bullet point"""
    formatted = f'{color}{symbol} {colorama.Style.RESET_ALL}{text}'
    return formatted


def format_markdown_line(issue):
    """Format an issue as a markdown line for TODO.md

    parameters:
        issue: dict with issue data from Gitea API

    returns:
        formatted markdown string
    """
    number = issue.get('number', '')
    title = issue.get('title', '')
    milestone = issue.get('milestone', {})
    milestone_title = milestone.get('title', '') if milestone else ''
    labels = issue.get('labels', [])
    label_names = ','.join(label.get('name', '') for label in labels)

    if milestone_title:
        milestone_str = f"**`{milestone_title}`**"
    else:
        milestone_str = "**`-`**"

    if label_names:
        label_str = f"`{label_names}`"
    else:
        label_str = "``"

    return f"- #{number} - {title} - {milestone_str} {label_str}"


def format_list(items, max_lines):
    """Return the first items of a list as text on multiple lines"""
    if max_lines == 0:
        return '\n'.join(items)
    first_items = items[:max_lines]
    return '\n'.join(first_items)


def get_gitea_issues(gitea_instance_url, gitea_token, repo, return_raw=False):
    """Fetch open issues from a Gitea repository

    parameters:
        gitea_instance_url: Full URL to Gitea instance (e.g., https://gitea.example.com)
        gitea_token: Personal access token with repo scope
        repo: Repository in format "username/repo"
        return_raw: If True, return raw issue data; if False, return formatted strings

    returns:
        list of "URL - Title" strings (or raw issue dicts if return_raw=True)
    """
    # URL-encode the repo path component (preserve the / between owner and repo name)
    # quote(..., safe='') encodes everything, then we replace %2F back to /
    repo_encoded = quote(repo, safe='')
    repo_encoded = repo_encoded.replace('%2F', '/')
    url = f"{gitea_instance_url}/api/v1/repos/{repo_encoded}/issues"

    params = {
        'state': 'open',
        'direction': 'desc',
        'sort': 'updated',
        'page': 1,
        'limit': 100  # Maximum allowed by Gitea API
    }
    headers = {
        'Authorization': f'token {gitea_token}',
        'Accept': 'application/json'
    }

    all_issues = []

    try:
        while True:
            response = requests.get(
                url,
                params=params,
                headers=headers,
                verify=False,
                timeout=REQUESTS_TIMEOUT
            )
            response.raise_for_status()
            issues = response.json()

            if not issues:
                break

            all_issues.extend(issues)

            # Check if we got fewer results than requested, meaning we've reached the end
            if len(issues) < params['limit']:
                break

            # Move to next page
            params['page'] += 1

        if return_raw:
            return all_issues

        result = []
        for issue in all_issues:
            issue_url = issue.get('html_url', '')
            title = issue.get('title', '')
            result.append(f'{issue_url} - {title}')

        return result

    except requests.exceptions.RequestException as e:
        error_msg = str(e)
        if hasattr(e, 'response') and e.response is not None:
            try:
                error_data = e.response.json()
                error_msg = f"{error_msg} - {error_data.get('message', '')}"
            except (ValueError, KeyError):
                pass
        print(f'{colorama.Fore.RED}ERROR: Failed to fetch issues: {error_msg}{colorama.Style.RESET_ALL}')
        return None


def get_gitea_issue_details(gitea_instance_url, gitea_token, repo, issue_number):
    """Fetch details of a specific Gitea issue

    parameters:
        gitea_instance_url: Full URL to Gitea instance
        gitea_token: Personal access token with repo scope
        repo: Repository in format "username/repo"
        issue_number: Issue number (not ID)

    returns:
        dict with issue details or None on error
    """
    repo_encoded = quote(repo, safe='')
    repo_encoded = repo_encoded.replace('%2F', '/')
    url = f"{gitea_instance_url}/api/v1/repos/{repo_encoded}/issues/{issue_number}"

    headers = {
        'Authorization': f'token {gitea_token}',
        'Accept': 'application/json'
    }

    try:
        response = requests.get(
            url,
            headers=headers,
            verify=False,
            timeout=REQUESTS_TIMEOUT
        )
        response.raise_for_status()
        return response.json()

    except requests.exceptions.RequestException as e:
        error_msg = str(e)
        if hasattr(e, 'response') and e.response is not None:
            try:
                error_data = e.response.json()
                error_msg = f"{error_msg} - {error_data.get('message', '')}"
            except (ValueError, KeyError):
                pass
        print(f'{colorama.Fore.RED}ERROR: Failed to fetch issue {issue_number}: {error_msg}{colorama.Style.RESET_ALL}')
        return None


def get_gitea_issue_comments(gitea_instance_url, gitea_token, repo, issue_number):
    """Fetch comments for a specific Gitea issue

    parameters:
        gitea_instance_url: Full URL to Gitea instance
        gitea_token: Personal access token with repo scope
        repo: Repository in format "username/repo"
        issue_number: Issue number (not ID)

    returns:
        list of comment dicts or empty list on error
    """
    repo_encoded = quote(repo, safe='')
    repo_encoded = repo_encoded.replace('%2F', '/')
    url = f"{gitea_instance_url}/api/v1/repos/{repo_encoded}/issues/{issue_number}/comments"

    headers = {
        'Authorization': f'token {gitea_token}',
        'Accept': 'application/json'
    }

    try:
        response = requests.get(
            url,
            headers=headers,
            verify=False,
            timeout=REQUESTS_TIMEOUT
        )
        response.raise_for_status()
        return response.json()

    except requests.exceptions.RequestException as e:
        print(f'{colorama.Fore.RED}ERROR: Failed to fetch comments for issue {issue_number}: {e}{colorama.Style.RESET_ALL}')
        return []


def display_issue_details(issue_data, gitea_instance_url, gitea_token, repo):
    """Display detailed information about an issue including comments"""
    if not issue_data:
        return

    print(f'\n{colorama.Style.BRIGHT}Title:{colorama.Style.RESET_ALL} {issue_data.get("title", "N/A")}')
    print(f'{colorama.Style.BRIGHT}State:{colorama.Style.RESET_ALL} {issue_data.get("state", "N/A")}')
    print(f'{colorama.Style.BRIGHT}Number:{colorama.Style.RESET_ALL} #{issue_data.get("number", "N/A")}')
    print(f'{colorama.Style.BRIGHT}Author:{colorama.Style.RESET_ALL} {issue_data.get("user", {}).get("username", "N/A")}')
    print(f'{colorama.Style.BRIGHT}Created:{colorama.Style.RESET_ALL} {issue_data.get("created_at", "N/A")}')
    print(f'{colorama.Style.BRIGHT}Updated:{colorama.Style.RESET_ALL} {issue_data.get("updated_at", "N/A")}')
    print(f'{colorama.Style.BRIGHT}HTML URL:{colorama.Style.RESET_ALL} {issue_data.get("html_url", "N/A")}')

    body = issue_data.get("body", "")
    if body:
        print(f'\n{colorama.Style.BRIGHT}Description:{colorama.Style.RESET_ALL}')
        print(body)

    comments = issue_data.get("comments", [])
    
    if isinstance(comments, int):
        if comments > 0:
            actual_comments = get_gitea_issue_comments(gitea_instance_url, gitea_token, repo, issue_data.get("number"))
            if actual_comments:
                print(f'\n{colorama.Style.BRIGHT}--- Comments ({len(actual_comments)}) ---{colorama.Style.RESET_ALL}')
                for i, comment in enumerate(actual_comments):
                    if i > 0:
                        print('\n' + '-' * 50)
                    author = comment.get("user", {}).get("username", "Unknown")
                    created = comment.get("created_at", "N/A")
                    comment_body = comment.get("body", "")
                    print(f'\n{colorama.Fore.YELLOW}[{author}] {colorama.Style.RESET_ALL}{created}')
                    print(f'{comment_body}')
    elif comments:
        print(f'\n{colorama.Style.BRIGHT}--- Comments ({len(comments)}) ---{colorama.Style.RESET_ALL}')
        for comment in comments:
            author = comment.get("user", {}).get("username", "Unknown")
            created = comment.get("created_at", "N/A")
            body = comment.get("body", "")
            print(f'\n{colorama.Fore.YELLOW}[{author}] {colorama.Style.RESET_ALL}{created}')
            print(f'{body}')


def main():
    """Main entry point for the Gitea issues script."""
    parser = argparse.ArgumentParser(
        description='Display open issues from a Gitea repository',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog='''
Examples:
  %(prog)s --repo myorg/myproject              # List issues from specified repo
  %(prog)s --repo myorg/myproject --limit 10   # Show only first 10 issues
  %(prog)s --repo myorg/myproject --issue 286  # Show details of issue #286
  %(prog)s --repo myorg/myproject --format markdown  # Output in TODO.md format

Configuration file (~/.config/gitea-issues.yml):
  GITEA_URL:  https://gitea.example.com
  GITEA_TOKEN: your-personal-access-token
  MAX_LINES:  20
  REQUESTS_TIMEOUT: 30
        '''
    )
    parser.add_argument(
        '--repo',
        type=str,
        required=True,
        help='Repository to query (format: username/repo)'
    )
    parser.add_argument(
        '--limit',
        type=int,
        default=MAX_LINES,
        help=f'Maximum number of issues to display (default: {MAX_LINES}, use 0 for no limit)'
    )
    parser.add_argument(
        '--issue',
        type=int,
        help='Show details of a specific issue by number'
    )
    parser.add_argument(
        '--format',
        type=str,
        choices=['list', 'markdown'],
        default='list',
        help='Output format: list (default) or markdown (for TODO.md)'
    )

    args = parser.parse_args()

    target_repo = args.repo

    # If --issue is provided, fetch and display that specific issue
    if args.issue:
        print_title(f"gitea issue #{args.issue}")
        issue_data = get_gitea_issue_details(GITEA_URL, GITEA_TOKEN, target_repo, args.issue)
        display_issue_details(issue_data, GITEA_URL, GITEA_TOKEN, target_repo)
        return

    # Print title
    print_title(f"gitea issues: {target_repo}")

    # Fetch issues
    if args.format == 'markdown':
        issues = get_gitea_issues(GITEA_URL, GITEA_TOKEN, target_repo, return_raw=True)
    else:
        issues = get_gitea_issues(GITEA_URL, GITEA_TOKEN, target_repo)

    if issues is None:
        # Error occurred
        sys.exit(1)

    if not issues:
        # No issues found - empty output is acceptable
        return

    # Format and display issues
    if args.format == 'markdown':
        # Output in TODO.md format
        output_lines = [format_markdown_line(issue) for issue in issues]
        if args.limit > 0:
            output_lines = output_lines[:args.limit]
        print('\n'.join(output_lines))
    else:
        # Output in list format (default)
        formatted_issues = [
            format_bullet_point('▧', colorama.Fore.GREEN, issue)
            for issue in issues
        ]
        output = format_list(formatted_issues, args.limit)
        print(output)


if __name__ == "__main__":
    main()
