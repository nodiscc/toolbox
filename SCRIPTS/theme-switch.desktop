[Desktop Entry]
Version=1.0
Name=Switch theme
Name[fr]=Changer de thème
Comment=Switch between light and dark theme
Comment[fr]=Alterner entre thème clair/sombre
Exec=/usr/local/bin/theme-switch
TryExec=/usr/local/bin/theme-switch
Icon=com.github.bluesabre.darkbar
Terminal=false
Type=Application
X-MultipleArgs=false
Categories=Utility
StartupNotify=false
